{
  manifest_version: "0.1.0",
  program: {
    image: "ghcr.io/andrew7234/officeqa-agentbeats:latest",
    entrypoint: [
      "python",
      "server.py",
      "--host",
      "0.0.0.0",
      "--port",
      "8081"
    ],
    env: {
      PROXY_URL: "${slots.proxy.url}",
      LOG_LEVEL: "INFO"
    },
    network: {
      endpoints: [
        { name: "endpoint", port: 8081 }
      ]
    }
  },
  config_schema: {
    type: "object",
    properties: {
    },
    required: [],
    additionalProperties: false,
  },
  slots: {
    proxy: { kind: "a2a" }
  },
  provides: {
    a2a: { kind: "a2a", endpoint: "endpoint" }
  },
  exports: {
    a2a: "a2a"
  },
  metadata: {
    assessment_config: {
      "dataset_url": "https://raw.githubusercontent.com/databricks/officeqa/6aa8c32/officeqa.csv",
      "num_questions": 246,
      "difficulty": "all",
      "tolerance": 0.0,
      "run_id": 3
    },
    participant_roles: ["officeqa_agent"]
  }
}
